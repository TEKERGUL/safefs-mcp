{
  "name": "@tekergul/safefs-mcp",
  "version": "1.1.0",
  "description": "A lightweight time machine for AI coding agents",
  "type": "module",
  "packageManager": "pnpm@10.34.3",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "safefs": "dist/cli.js",
    "safefs-mcp": "dist/cli.js"
  },
  "files": [
    "assets",
    "dist",
    "examples",
    "README.md",
    "LICENSE",
    "SECURITY.md",
    "CONTRIBUTING.md",
    "AGENTS.md"
  ],
  "scripts": {
    "dev": "tsx src/cli.ts serve --root .",
    "build": "tsup src/index.ts src/cli.ts --format esm --dts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "pack:dry-run": "npm pack --dry-run",
    "prepublishOnly": "pnpm build && pnpm test"
  },
  "keywords": [
    "mcp",
    "ai",
    "coding-agent",
    "filesystem",
    "rollback",
    "undo",
    "claude",
    "cursor",
    "codex",
    "gemini",
    "safety"
  ],
  "author": "tekergul",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TEKERGUL/safefs-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/TEKERGUL/safefs-mcp/issues"
  },
  "homepage": "https://github.com/TEKERGUL/safefs-mcp#readme",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "js-yaml": "^4.1.0",
    "picomatch": "^4.0.2",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.10.0",
    "@types/picomatch": "^3.0.1",
    "tsup": "^8.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
